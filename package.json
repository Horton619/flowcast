{
  "name": "flowcast",
  "version": "1.0.1",
  "description": "Audio cue playback for live events — Visual Entropy Productions",
  "main": "main.js",
  "homepage": "https://veproductions.net",
  "author": {
    "name": "Visual Entropy Productions"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Horton619/flowcast.git"
  },
  "scripts": {
    "start": "electron .",
    "backend:build": "cd backend && venv/bin/pyinstaller --clean main.spec",
    "build:mac:dir": "electron-builder --mac --dir",
    "build:win": "electron-builder --win --dir",
    "pack": "electron-builder --dir",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "release:mac": "electron-builder --mac --publish always",
    "release:win": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "build": {
    "appId": "net.veproductions.flowcast",
    "productName": "FlowCast",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "backend/dist/**/*",
      "!backend/venv/**/*",
      "!backend/__pycache__/**/*",
      "!**/.DS_Store",
      "!**/*.flowcast"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Horton619",
        "repo": "flowcast"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "identity": null,
      "extraResources": [
        { "from": "backend/dist/flowcast_backend", "to": "backend/flowcast_backend" }
      ]
    },
    "dmg": {
      "background": "build/dmg-bg.png",
      "iconSize": 100,
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 175, "y": 245, "type": "file" },
        { "x": 385, "y": 245, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "extraResources": [
        { "from": "backend/dist/flowcast_backend.exe", "to": "backend/flowcast_backend.exe" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
